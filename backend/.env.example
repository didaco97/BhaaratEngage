# Runtime
NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:8080
LOG_LEVEL=info

# Repository selection and auth
BACKEND_DATA_SOURCE=auto
API_AUTH_MODE=disabled
API_AUTH_DEV_USER_ID=
API_AUTH_DEV_ORGANIZATION_ID=
API_AUTH_DEV_ROLE=workspace_admin
DEFAULT_ORGANIZATION_ID=
DEFAULT_ORGANIZATION_SLUG=

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_INTEGRATION_TEST=false

# Redis / workers
REDIS_URL=redis://localhost:6379
WORKER_QUEUE_PREFIX=bharatengage
WORKER_CONCURRENCY=5
WORKER_SCHEDULER_INTERVAL_MS=60000

# Public callback base URL
PUBLIC_BASE_URL=http://localhost:4000

# Plivo voice
PLIVO_AUTH_ID=your-plivo-auth-id
PLIVO_AUTH_TOKEN=your-plivo-auth-token
PLIVO_PHONE_NUMBER=your-plivo-phone-number
PLIVO_VALIDATE_SIGNATURES=false

# AI providers
SARVAM_API_KEY=your-sarvam-api-key
OPENAI_API_KEY=your-openai-api-key
OPENAI_VOICE_EXTRACTION_MODEL=gpt-4o-mini

# Security
SENSITIVE_DATA_ENCRYPTION_KEY=change-me-to-a-long-random-secret
